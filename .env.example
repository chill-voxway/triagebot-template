# --- TriageBot · variables de entorno ---
# Copia este archivo a .env y rellena los valores:  cp .env.example .env
# NO se usan entornos virtuales. Intérprete del proyecto: SIEMPRE Python 3.12.
# .env NUNCA se commitea (está en .gitignore). Comparte cambios vía este .env.example.

# Intérprete de Python del proyecto (siempre 3.12). En Windows con el py launcher:
PYTHON_BIN=py -3.12

# API key de OpenRouter (https://openrouter.ai/keys) — requerida para clasificar.
OPENROUTER_API_KEY=

# (Opcional) URL de la base de datos. Por defecto: sqlite:///triagebot.db
# DATABASE_URL=sqlite:///triagebot.db
